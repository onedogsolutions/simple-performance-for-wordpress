msgstr ""

#: src/components/FontsSettings.jsx:60
msgid "These fonts were localized by an older version of this plugin that could drop font weights (e.g. a font family would render bold everywhere, even where a lighter weight was specified). Click \"Scan fonts now\" below to regenerate them correctly."
msgstr ""

#: src/components/FontsSettings.jsx:69
msgid "Self-host Google Fonts"
msgstr ""

#: src/components/FontsSettings.jsx:73
msgid "Serves discovered Google Fonts from your own site instead of fonts.googleapis.com/fonts.gstatic.com. Run a scan first — this has no effect until fonts have been discovered."
msgstr ""

#: src/components/FontsSettings.jsx:85
msgid "Font discovery"
msgstr ""

#: src/components/FontsSettings.jsx:89
msgid "Loads your homepage and detects the Google Fonts your theme and plugins actually enqueue, then downloads the .woff2 files locally. Fetches your homepage and Google’s stylesheets."
msgstr ""

#: src/components/FontsSettings.jsx:102
msgid "Scanning…"
msgstr ""

#: src/components/FontsSettings.jsx:106
msgid "Scan fonts now"
msgstr ""

#: src/components/FontsSettings.jsx:113
msgid "Last scan:"
msgstr ""

#. translators: 1: family count, 2: file count.
#: src/components/FontsSettings.jsx:131
#, js-format
msgid "%1$d families · %2$d files localized"
msgstr ""

#: src/components/FontsSettings.jsx:148
msgid "No Google Fonts detected yet."
msgstr ""

#: src/components/FontsSettings.jsx:160
msgid "Manual font weights"
msgstr ""

#: src/components/FontsSettings.jsx:166
msgid "If a CDN or optimizer (e.g. QUIC.cloud) hides some weights from automatic discovery, declare them here. One family per line as “Family:weights”, e.g. “Roboto Condensed:400,700”. Append “i” for italics (400i). A bare family name defaults to 400. Declared weights are downloaded straight from Google on the next scan, regardless of what the front end exposes."
msgstr ""

#: src/components/FontsSettings.jsx:189
msgid "Extra pages to scan"
msgstr ""

#: src/components/FontsSettings.jsx:195
msgid "The scan already checks your homepage plus your most recent post and page. Add any other URLs whose fonts differ — a shop page, landing page, or custom template. One per line, as a path (/shop/) or full URL on this site."
msgstr ""

#: src/components/HardeningSettings.jsx:9
msgid "Active"
msgstr ""

#: src/components/HardeningSettings.jsx:14
msgid "File missing"
msgstr ""

#: src/components/HardeningSettings.jsx:19
msgid "File modified"
msgstr ""

#: src/components/HardeningSettings.jsx:54
msgid "Restore"
msgstr ""

#: src/components/HardeningSettings.jsx:76
msgid "Directory Hardening"
msgstr ""

#: src/components/HardeningSettings.jsx:80
msgid "Server-level restrictions that reduce each directory’s attack surface. On OpenLiteSpeed these .htaccess rules are honored only when \"Allow Override\" is enabled for the vhost (LiteSpeed WebAdmin → Rewrite → Auto Load from .htaccess); when override is off they have no effect but cause no harm."
msgstr ""

#: src/components/HardeningSettings.jsx:86
msgid "Block direct PHP execution in wp-content/plugins"
msgstr ""

#: src/components/HardeningSettings.jsx:90
msgid "Drops an .htaccess file into the plugins directory that denies direct requests to .php files. A small number of legacy plugins serve front-facing PHP from /plugins/ — disable this if something breaks."
msgstr ""

#: src/components/HardeningSettings.jsx:109
msgid "Block direct PHP execution in uploads"
msgstr ""

#: src/components/HardeningSettings.jsx:113
msgid "Drops an .htaccess file into wp-content/uploads that denies direct requests to .php files. The uploads directory is the most common place a malicious script is planted through a vulnerable upload form; images and other media are unaffected."
msgstr ""

#: src/components/HardeningSettings.jsx:133
msgid "Site Hardening"
msgstr ""

#: src/components/HardeningSettings.jsx:137
msgid "Application-level protections that apply regardless of the web server configuration."
msgstr ""

#: src/components/HardeningSettings.jsx:143
msgid "Disable the theme & plugin file editor"
msgstr ""

#: src/components/HardeningSettings.jsx:147
msgid "Removes the built-in code editor under Appearance and Plugins (sets DISALLOW_FILE_EDIT), so an attacker who gains admin access cannot edit PHP directly from the dashboard."
msgstr ""

#: src/components/HardeningSettings.jsx:161
msgid "Block author enumeration"
msgstr ""

#: src/components/HardeningSettings.jsx:165
msgid "Redirects ?author=N and /author/slug/ probes from logged-out visitors to the home page, preventing usernames from being harvested for brute-force attacks. Complements disabling the REST users endpoint."
msgstr ""

#: src/components/HardeningSettings.jsx:177
msgid "Send security headers"
msgstr ""

#: src/components/HardeningSettings.jsx:181
msgid "Adds X-Content-Type-Options: nosniff, X-Frame-Options: SAMEORIGIN, a Referrer-Policy, and a restrictive Permissions-Policy to front-end responses. Conservative defaults with no side effects. Content-Security-Policy is configured separately below."
msgstr ""

#: src/components/HardeningSettings.jsx:203
msgid "HTTP Strict Transport Security"
msgstr ""

#: src/components/HardeningSettings.jsx:207
msgid "Tells browsers to only ever connect to your site over HTTPS for a set duration, protecting against protocol-downgrade attacks and cookie hijacking on insecure networks. Only sent when the request is actually HTTPS (including behind a reverse proxy). Once a browser has seen this header, it will refuse plain HTTP connections until max-age expires — make sure HTTPS works reliably before enabling."
msgstr ""

#: src/components/HardeningSettings.jsx:213
msgid "Send Strict-Transport-Security header"
msgstr ""

#: src/components/HardeningSettings.jsx:217
msgid "Only sent on HTTPS responses. Do not enable if your site is not fully served over HTTPS."
msgstr ""

#: src/components/HardeningSettings.jsx:231
msgid "Max age"
msgstr ""

#: src/components/HardeningSettings.jsx:235
msgid "How long browsers should remember to force HTTPS for this site."
msgstr ""

#: src/components/HardeningSettings.jsx:251
msgid "1 day"
msgstr ""

#: src/components/HardeningSettings.jsx:257
msgid "1 week"
msgstr ""

#: src/components/HardeningSettings.jsx:263
msgid "1 month"
msgstr ""

#: src/components/HardeningSettings.jsx:269
msgid "6 months"
msgstr ""

#: src/components/HardeningSettings.jsx:275
msgid "1 year (recommended)"
msgstr ""

#: src/components/HardeningSettings.jsx:281
msgid "2 years"
msgstr ""

#: src/components/HardeningSettings.jsx:290
msgid "Include subdomains"
msgstr ""

#: src/components/HardeningSettings.jsx:294
msgid "Applies the policy to every subdomain too. Only enable once you have confirmed every subdomain is served over HTTPS — otherwise those subdomains will become unreachable until max-age expires."
msgstr ""

#: src/components/HardeningSettings.jsx:308
msgid "Preload"
msgstr ""

#: src/components/HardeningSettings.jsx:312
msgid "Opts into browser HSTS preload lists (requires includeSubDomains, max-age of at least 1 year, and submission to hstspreload.org). This is very difficult to reverse — only enable if you are certain every subdomain, now and in the future, will be HTTPS-only."
msgstr ""

#: src/components/RestApiSettings.jsx:58
msgid "Restrict or disable REST API routes to reduce your attack surface and prevent user enumeration."
msgstr ""

#: src/components/RestApiSettings.jsx:64
msgid "Require authentication"
msgstr ""

#: src/components/RestApiSettings.jsx:68
msgid "Blocks all REST API requests from logged-out visitors, except whitelisted routes below."
msgstr ""

#: src/components/RestApiSettings.jsx:81
msgid "Disable namespaces"
msgstr ""

#: src/components/RestApiSettings.jsx:87
msgid "Unregisters matching routes entirely (404, not 403) for logged-out visitors, to prevent user enumeration and scanning. Logged-in users who can edit content are never restricted."
msgstr ""

#: src/components/RestApiSettings.jsx:130
msgid "Advanced: one route prefix per line (e.g. wp/v2/users)"
msgstr ""

#: src/components/RestApiSettings.jsx:150
msgid "Whitelist routes"
msgstr ""

#: src/components/RestApiSettings.jsx:154
msgid "Route prefixes that always bypass both the auth gate and namespace disabling (e.g. Contact Form 7, WooCommerce). This plugin’s own settings API (spfw/v1) is always exempt automatically."
msgstr ""

#: src/components/WooCommerceSettings.jsx:21
msgid "Storefront"
msgstr ""

#: src/components/WooCommerceSettings.jsx:22
msgid "Trim WooCommerce assets on the front end so non-store pages stay lean."
msgstr ""

#: src/components/WooCommerceSettings.jsx:29
msgid "Disable cart fragments"
msgstr ""

#: src/components/WooCommerceSettings.jsx:33
msgid "Stops the AJAX cart-fragments request (?wc-ajax=get_refreshed_fragments) everywhere except the cart and checkout. The single biggest WooCommerce speed win, and it lets full-page caching work."
msgstr ""

#: src/components/WooCommerceSettings.jsx:40
